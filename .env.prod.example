# =============================================================
# JayPolyMind — Production Config (VPS, no Dokploy)
# =============================================================
# Copy to .env and fill in real values before deploying.
# =============================================================

# ===== Domain =====
# Set DOMAIN when running compose:
#   DOMAIN=test.haragy.top docker compose -f docker-compose.prod.yml up -d
# Or put it here:
DOMAIN=test.haragy.top
ACME_EMAIL=gkaitmazov@proton.me

# ===== LLM (OpenRouter or any OpenAI-compatible) =====
LLM_API_KEY=your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=openai/gpt-4o-mini

# ===== Embeddings (OpenRouter) =====
EMBEDDING_API_KEY=your-openrouter-key
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===== Neo4j =====
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-strong-password

# ===== Auth =====
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-strong-password
DEMO_LOGIN=demo
DEMO_PASSWORD=change-me-demo-password
